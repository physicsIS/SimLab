#Simulación 2
# Descripción: Visualización de líneas de corriente alrededor de una esfera utilizando Web VPython.

# escenario para la simulación
scene.background = color.black
scene.width = 1000
scene.height = 600
scene.range = 3.5

# diseño de pelota
R = 0.8
tenis_color = vector(0.8, 1, 0)
ball = sphere(pos=vector(0,0,0), radius=R, color=tenis_color, shininess=0.1)

# costura de la pelota
costura = curve(color=color.white, radius=0.025)
for t in arange(0, 2*pi + 0.05, 0.05):
    x = R * cos(t)
    y = R * sin(t) * cos(t) * 1.1
    z = R * sin(t) * sin(t) * 1.1 - (R/1.4)
    pos_final = vector(x, y, z)
    pos_final.mag = R + 0.01
    costura.append(pos_final)

# líneas de corriente
# valores negativos para que el giro sea horario
VEL_ANGULAR_FLUJO = -0.04
VEL_ROTACION_PELOTA = -0.05

RADIOS = [1.2, 1.6, 2.0, 2.4, 2.8]
N_SEGMENTOS = 12
LARGO_ARCO = -0.2

segmentos = []
for r in RADIOS:
    for i in range(N_SEGMENTOS):
        theta = (i / N_SEGMENTOS) * 2 * pi
        s = cylinder(
            pos=vector(r*cos(theta), r*sin(theta), 0),
            axis=vector(0,0,0),
            radius=0.015,
            color=color.white,
            opacity=0.7
        )
        s.mi_radio = r
        s.theta = theta
        segmentos.append(s)

# animación
while True:
    rate(60)

    # rotación de pelota en sentido horario
    ball.rotate(angle=VEL_ROTACION_PELOTA, axis=vector(0,0,1))
    costura.rotate(angle=VEL_ROTACION_PELOTA, axis=vector(0,0,1))

    # movemos segmentos
    for s in segmentos:
        s.theta += VEL_ANGULAR_FLUJO

        p1 = vector(
            s.mi_radio * cos(s.theta),
            s.mi_radio * sin(s.theta),
            0
        )

        p2 = vector(
            s.mi_radio * cos(s.theta + LARGO_ARCO),
            s.mi_radio * sin(s.theta + LARGO_ARCO),
            0
        )

        s.pos = p1
        s.axis = p2 - p1
